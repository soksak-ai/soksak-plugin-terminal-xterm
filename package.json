{
  "name": "soksak-plugin-terminal-xterm",
  "private": true,
  "version": "0.0.3",
  "type": "module",
  "description": "soksak terminal plugin — xterm.js content view driven by core PTY",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node build.mjs && npx --yes soksak-plugin-doctor .",
    "test": "vitest run --no-cache",
    "test-unit": "npm run typecheck && vitest run"
  },
  "dependencies": {
    "@xterm/xterm": "^6.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-webgl": "^0.19.0",
    "soksak-kit-terminal-common": "github:soksak-ai/soksak-kit-terminal-common"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.24.2",
    "typescript": "~5.9.3",
    "vitest": "^2.1.8"
  },
  "soksakRelease": {
    "kind": "plugin",
    "id": "soksak-plugin-terminal-xterm",
    "repository": "https://github.com/soksak-ai/soksak-plugin-terminal-xterm",
    "manifest": "release.json"
  }
}
