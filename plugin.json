{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-terminal",
  "name": {
    "ko": "터미널",
    "en": "Terminal"
  },
  "version": "0.0.1",
  "repo": "https://github.com/soksak-ai/soksak-plugin-terminal.git",
  "description": {
    "ko": "xterm.js 터미널 패널 — 코어 PTY 를 직접 구동.",
    "en": "xterm.js terminal pane driven by core PTY."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "commands",
    "programs",
    "pty",
    "data",
    "terminal",
    "terminal:read"
  ],
  "configuration": [
    {
      "key": "shell",
      "type": "string",
      "default": "",
      "title": {
        "ko": "셸",
        "en": "Shell"
      }
    },
    {
      "key": "xtermRenderer",
      "type": "enum",
      "enum": [
        "dom",
        "webgl"
      ],
      "enumLabels": [
        {
          "ko": "DOM",
          "en": "DOM"
        },
        {
          "ko": "WebGL (GPU)",
          "en": "WebGL (GPU)"
        }
      ],
      "default": "webgl",
      "title": {
        "ko": "터미널 렌더러",
        "en": "Terminal renderer"
      }
    },
    {
      "key": "fontFamily",
      "type": "string",
      "default": "\"JetBrains Mono\", \"SF Mono\", \"Cascadia Code\", Menlo, Consolas, \"Courier New\", monospace",
      "title": {
        "ko": "글꼴",
        "en": "Font family"
      }
    },
    {
      "key": "fontSize",
      "type": "number",
      "default": 13,
      "min": 8,
      "max": 32,
      "title": {
        "ko": "글꼴 크기",
        "en": "Font size"
      }
    },
    {
      "key": "scrollback",
      "type": "number",
      "default": 10000,
      "min": 0,
      "max": 200000,
      "title": {
        "ko": "스크롤백 줄 수",
        "en": "Scrollback lines"
      }
    },
    {
      "key": "cursorBlink",
      "type": "boolean",
      "default": true,
      "title": {
        "ko": "커서 깜빡임",
        "en": "Cursor blink"
      }
    },
    {
      "key": "cursorStyle",
      "type": "enum",
      "enum": [
        "block",
        "underline",
        "bar"
      ],
      "enumLabels": [
        {
          "ko": "블록",
          "en": "Block"
        },
        {
          "ko": "밑줄",
          "en": "Underline"
        },
        {
          "ko": "막대",
          "en": "Bar"
        }
      ],
      "default": "block",
      "title": {
        "ko": "커서 모양",
        "en": "Cursor style"
      }
    }
  ],
  "contributes": {
    "programs": [
      {
        "id": "terminal",
        "title": {
          "ko": "터미널",
          "en": "Terminal"
        },
        "kind": "view",
        "view": "content"
      }
    ],
    "views": [
      {
        "id": "content",
        "title": {
          "ko": "터미널",
          "en": "Terminal"
        },
        "icon": ">_",
        "placements": [
          "content"
        ],
        "defaultPlacement": "content",
        "status": [
          "connecting",
          "error"
        ]
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "ko": "플러그인 적재/버전 확인(E2E)",
          "en": "Ping (load/version check)"
        }
      },
      {
        "name": "send",
        "title": {
          "ko": "텍스트 전송",
          "en": "Send Text"
        }
      },
      {
        "name": "clear",
        "title": {
          "ko": "지우기",
          "en": "Clear"
        }
      },
      {
        "name": "resume",
        "title": {
          "ko": "세션 이어가기",
          "en": "Resume Session"
        }
      }
    ],
    "nodes": [
      {
        "id": "terminal",
        "description": {
          "ko": "xterm.js 터미널 컨테이너",
          "en": "xterm.js terminal container"
        }
      }
    ]
  }
}
