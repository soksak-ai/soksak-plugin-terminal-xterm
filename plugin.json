{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-terminal-xterm",
  "name": {
    "ko": "터미널",
    "en": "Terminal"
  },
  "version": "0.0.3",
  "renamedFrom": "soksak-plugin-terminal",
  "description": {
    "ko": "xterm.js 터미널 패널 — 코어 PTY 를 직접 구동.",
    "en": "xterm.js terminal pane driven by core PTY."
  },
  "entry": "main.js",
  "implements": [
    {
      "id": "soksak-spec-plugin-terminal",
      "version": "0.0.1"
    }
  ],
  "sidecars": [
    {
      "name": "terminal-alacritty",
      "interface": {
        "id": "soksak-spec-sidecar-terminal",
        "range": "0.0.1"
      }
    }
  ],
  "permissions": [
    "ui",
    "commands",
    "programs",
    "process",
    "pty",
    "data",
    "terminal",
    "terminal:read"
  ],
  "configuration": [
    {
      "key": "shell",
      "type": "string",
      "default": "",
      "title": {
        "ko": "셸",
        "en": "Shell"
      }
    },
    {
      "key": "xtermRenderer",
      "type": "enum",
      "enum": [
        "dom",
        "webgl"
      ],
      "enumLabels": [
        {
          "ko": "DOM",
          "en": "DOM"
        },
        {
          "ko": "WebGL (GPU)",
          "en": "WebGL (GPU)"
        }
      ],
      "default": "webgl",
      "title": {
        "ko": "터미널 렌더러",
        "en": "Terminal renderer"
      }
    },
    {
      "key": "fontFamily",
      "type": "string",
      "default": "\"JetBrains Mono\", \"SF Mono\", \"Cascadia Code\", Menlo, Consolas, \"Courier New\", monospace",
      "title": {
        "ko": "글꼴",
        "en": "Font family"
      }
    },
    {
      "key": "fontSize",
      "type": "number",
      "default": 13,
      "min": 8,
      "max": 32,
      "title": {
        "ko": "글꼴 크기",
        "en": "Font size"
      }
    },
    {
      "key": "scrollback",
      "type": "number",
      "default": 10000,
      "min": 0,
      "max": 200000,
      "title": {
        "ko": "스크롤백 줄 수",
        "en": "Scrollback lines"
      }
    },
    {
      "key": "cursorBlink",
      "type": "boolean",
      "default": true,
      "title": {
        "ko": "커서 깜빡임",
        "en": "Cursor blink"
      }
    },
    {
      "key": "cursorStyle",
      "type": "enum",
      "enum": [
        "block",
        "underline",
        "bar"
      ],
      "enumLabels": [
        {
          "ko": "블록",
          "en": "Block"
        },
        {
          "ko": "밑줄",
          "en": "Underline"
        },
        {
          "ko": "막대",
          "en": "Bar"
        }
      ],
      "default": "block",
      "title": {
        "ko": "커서 모양",
        "en": "Cursor style"
      }
    },
    {
      "key": "splitMode",
      "type": "enum",
      "default": "tab",
      "title": {
        "ko": "분할 방식",
        "en": "Split mode"
      },
      "description": {
        "ko": "터미널 분할을 탭(별도 패널)으로 할지 탭 내부(뷰 안 pane)로 할지.",
        "en": "Whether a terminal split makes a new tab (panel) or an internal pane within the view."
      },
      "enum": [
        "tab",
        "within-tab"
      ],
      "enumLabels": [
        {
          "ko": "탭 분할",
          "en": "Tab split"
        },
        {
          "ko": "탭 내 분할",
          "en": "Within-tab split"
        }
      ]
    }
  ],
  "contributes": {
    "programs": [
      {
        "id": "terminal-xterm",
        "title": {
          "ko": "터미널",
          "en": "Terminal"
        },
        "kind": "view",
        "view": "content"
      }
    ],
    "views": [
      {
        "id": "content",
        "title": {
          "ko": "터미널",
          "en": "Terminal"
        },
        "icon": ">_",
        "placements": [
          "content"
        ],
        "defaultPlacement": "content",
        "status": [
          "connecting",
          "error"
        ]
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "ko": "플러그인 적재/버전 확인(E2E)",
          "en": "Ping (load/version check)"
        }
      },
      {
        "name": "send",
        "title": {
          "ko": "텍스트 전송",
          "en": "Send Text"
        }
      },
      {
        "name": "clear",
        "title": {
          "ko": "지우기",
          "en": "Clear"
        }
      },
      {
        "name": "resume",
        "title": {
          "ko": "세션 이어가기",
          "en": "Resume Session"
        }
      },
      {
        "name": "perf.stats",
        "title": {
          "ko": "성능 카운터 읽기",
          "en": "Read Performance Counters"
        }
      },
      {
        "name": "perf.echo",
        "title": {
          "ko": "입력 에코 왕복 측정",
          "en": "Measure Input Echo Roundtrip"
        }
      },
      {
        "name": "split-pane",
        "title": {
          "ko": "탭 내 분할",
          "en": "Split Pane (Within-Tab)"
        }
      },
      {
        "name": "panes",
        "title": {
          "ko": "탭 내 pane 목록",
          "en": "List Panes (Within-Tab)"
        }
      },
      {
        "name": "close-pane",
        "title": {
          "ko": "탭 내 pane 닫기",
          "en": "Close Pane (Within-Tab)"
        }
      }
    ],
    "nodes": [
      {
        "id": "terminal-xterm",
        "description": {
          "ko": "xterm.js 터미널 컨테이너",
          "en": "xterm.js terminal container"
        }
      }
    ]
  }
}
